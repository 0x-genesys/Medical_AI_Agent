# Multimodal Medical Assistant Environment Configuration

# Model Configuration
LLM_MODEL=llama3
MODEL_TEMPERATURE=0.1
MODEL_MAX_TOKENS=2000

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# Storage Configuration
TEMP_DIR=temp
UPLOAD_DIR=uploads
OUTPUT_DIR=output
MAX_FILE_SIZE_MB=50

# Security Configuration
ENABLE_DEIDENTIFICATION=true
ENABLE_AUDIT_LOGGING=true
HIPAA_COMPLIANT=true

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
